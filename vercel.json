{
  "version": 2,
  "builds": [
    {
      "src": "getgig/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.12"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "getgig/static/$1",
      "continue": true
    },
    {
      "src": "/(.*)",
      "dest": "getgig/wsgi.py"
    }
  ]
}